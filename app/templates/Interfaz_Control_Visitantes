<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IMPLESEG - Control de Acceso</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- SweetAlert2 para popups bonitos -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            background-color: #0f172a; /* Fondo oscuro inspirado en la imagen */
            background-image: radial-gradient(circle at top right, #1e293b, #0f172a);
            min-height: 100vh;
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .btn-ingreso:hover { box-shadow: 0 0 20px rgba(249, 115, 22, 0.4); border-color: #f97316; }
        .btn-salida:hover { box-shadow: 0 0 20px rgba(34, 197, 94, 0.4); border-color: #22c55e; }
        
        /* Estilos para los formularios */
        input, select {
            background-color: #1e293b;
            color: white;
            border: 1px solid #334155;
            padding: 0.75rem;
            border-radius: 0.5rem;
            width: 100%;
        }
        input:focus, select:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
        }
    </style>
</head>
<body class="flex flex-col items-center p-6 relative overflow-hidden">

    <!-- Header / Logo / Reloj -->
    <div class="w-full max-w-5xl flex justify-between items-center mb-12 mt-4 relative z-10">
        <div class="flex items-center gap-4">
            <!-- Logo Icono (simulado) -->
            <div class="w-14 h-14 bg-orange-600 rounded-lg flex items-center justify-center shadow-lg transform rotate-3">
                <svg class="w-8 h-8 text-white -rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path></svg>
            </div>
            <div>
                <h1 class="text-3xl font-black tracking-wider text-white">IMPLESEG</h1>
                <p class="text-orange-500 font-semibold tracking-widest text-xs">CONTROL DE ACCESO - VISITANTES</p>
            </div>
        </div>
        
        <!-- Reloj en vivo -->
        <div class="glass-panel px-6 py-3 rounded-xl border border-gray-700 text-center">
            <div id="clock-time" class="text-2xl font-bold text-white tracking-widest">--:--:--</div>
            <div id="clock-date" class="text-xs text-gray-400 font-semibold uppercase tracking-wider mt-1">-- --- ----</div>
        </div>
    </div>

    <!-- Indicador de Estado -->
    <div id="status-indicator" class="text-sm font-medium text-gray-300 tracking-[0.2em] mb-8 flex items-center gap-2 relative z-10">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        SISTEMA ACTIVO · SELECCIONE UNA OPCIÓN
    </div>

    <!-- CONTENEDOR PRINCIPAL -->
    <div class="w-full max-w-5xl relative z-10">
        
        <!-- VISTA: BOTONES PRINCIPALES -->
        <div id="view-menu" class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Botón Ingreso -->
            <button onclick="showView('view-ingreso')" class="btn-ingreso glass-panel rounded-2xl p-10 flex flex-col items-center justify-center transition-all duration-300 group cursor-pointer border border-transparent">
                <div class="w-24 h-24 rounded-full border-2 border-orange-500 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform bg-orange-500/10">
                    <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
                </div>
                <h2 class="text-4xl font-black text-orange-500 mb-4 tracking-wider">INGRESO</h2>
                <p class="text-gray-400 text-center text-sm leading-relaxed max-w-xs">
                    Registre su entrada completando el formulario de visitante. Tenga su cédula a la mano.
                </p>
            </button>

            <!-- Botón Salida -->
            <button onclick="showView('view-salida')" class="btn-salida glass-panel rounded-2xl p-10 flex flex-col items-center justify-center transition-all duration-300 group cursor-pointer border border-transparent">
                <div class="w-24 h-24 rounded-full border-2 border-green-500 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform bg-green-500/10">
                    <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </div>
                <h2 class="text-4xl font-black text-green-500 mb-4 tracking-wider">SALIDA</h2>
                <p class="text-gray-400 text-center text-sm leading-relaxed max-w-xs">
                    Registre su salida de las instalaciones con el número de cédula que usó al ingresar.
                </p>
            </button>
        </div>

        <!-- VISTA: FORMULARIO DE INGRESO -->
        <div id="view-ingreso" class="hidden glass-panel rounded-2xl p-8 border border-orange-500/30 shadow-2xl shadow-orange-900/20 max-w-3xl mx-auto">
            <div class="flex justify-between items-center mb-6 border-b border-gray-700 pb-4">
                <h2 class="text-2xl font-bold text-orange-500 flex items-center gap-2">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
                    Registro de Ingreso
                </h2>
                <button onclick="showView('view-menu')" class="text-gray-400 hover:text-white transition-colors">Volver al menú ✖</button>
            </div>
            
            <form id="form-ingreso" onsubmit="enviarIngreso(event)" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-400 mb-1">N° Cédula *</label>
                    <input type="number" id="in_cedula" required placeholder="Ej: 1020304050">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-400 mb-1">Nombres Completos *</label>
                    <input type="text" id="in_nombre" required placeholder="Nombres y Apellidos">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-400 mb-1">Entidad / Empresa</label>
                    <input type="text" id="in_empresa" placeholder="Empresa a la que representa">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-400 mb-1">Tipo de Visitante *</label>
                    <select id="in_tipo" required>
                        <option value="">Seleccione...</option>
                        <option value="PROVEEDOR">PROVEEDOR</option>
                        <option value="VISITANTE">VISITANTE</option>
                        <option value="CONTRATISTA">CONTRATISTA</option>
                        <option value="CLIENTE">CLIENTE</option>
                        <option value="ENTREVISTA">ENTREVISTA</option>
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-gray-400 mb-1">A Quién Visita *</label>
                    <input type="text" id="in_visita_a" required placeholder="Nombre de la persona en Impleseg">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-400 mb-1">¿Tiene ARL? *</label>
                    <select id="in_arl" required>
                        <option value="">Seleccione...</option>
                        <option value="SI">SÍ</option>
                        <option value="NO">NO</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-400 mb-1">N° Tarjeta Asignada *</label>
                    <input type="text" id="in_tarjeta" required placeholder="Ej: T-01">
                </div>
                
                <div class="md:col-span-2 mt-6">
                    <button type="submit" id="btn-submit-ingreso" class="w-full bg-orange-600 hover:bg-orange-500 text-white font-bold py-4 rounded-xl shadow-lg transition-colors flex justify-center items-center gap-2">
                        REGISTRAR INGRESO
                    </button>
                </div>
            </form>
        </div>

        <!-- VISTA: FORMULARIO DE SALIDA -->
        <div id="view-salida" class="hidden glass-panel rounded-2xl p-8 border border-green-500/30 shadow-2xl shadow-green-900/20 max-w-md mx-auto mt-10">
            <div class="flex justify-between items-center mb-6 border-b border-gray-700 pb-4">
                <h2 class="text-2xl font-bold text-green-500 flex items-center gap-2">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    Registro de Salida
                </h2>
                <button onclick="showView('view-menu')" class="text-gray-400 hover:text-white transition-colors">Volver ✖</button>
            </div>
            
            <form id="form-salida" onsubmit="enviarSalida(event)">
                <div class="mb-6 text-center">
                    <p class="text-gray-400 mb-6">Por favor, ingrese su número de cédula para registrar su hora de salida y finalización de la visita.</p>
                    
                    <label class="block text-sm font-semibold text-gray-400 mb-1 text-left">N° Cédula *</label>
                    <input type="number" id="out_cedula" required placeholder="Ingrese su cédula" class="text-center text-xl tracking-widest font-bold py-4">
                </div>
                
                <button type="submit" id="btn-submit-salida" class="w-full bg-green-600 hover:bg-green-500 text-white font-bold py-4 rounded-xl shadow-lg transition-colors flex justify-center items-center gap-2">
                    REGISTRAR SALIDA
                </button>
            </form>
        </div>

    </div>

    <script>
        // 1. Reloj en vivo
        function updateClock() {
            const now = new Date();
            // Formato de hora HH:MM:SS
            document.getElementById('clock-time').innerText = now.toLocaleTimeString('es-CO', { hour12: false });
            
            // Formato de fecha MAR, 21 JUL 2026
            const options = { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' };
            let dateStr = now.toLocaleDateString('es-CO', options).replace(/\./g, '').toUpperCase();
            document.getElementById('clock-date').innerText = dateStr;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // 2. Control de Vistas (SPA feeling)
        function showView(viewId) {
            document.getElementById('view-menu').classList.add('hidden');
            document.getElementById('view-ingreso').classList.add('hidden');
            document.getElementById('view-salida').classList.add('hidden');
            
            document.getElementById(viewId).classList.remove('hidden');
            
            // Textos de ayuda
            const status = document.getElementById('status-indicator');
            if(viewId === 'view-menu') status.innerHTML = '<span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span> SISTEMA ACTIVO · SELECCIONE UNA OPCIÓN';
            if(viewId === 'view-ingreso') status.innerHTML = '<span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span> MÓDULO DE INGRESO ACTIVADO';
            if(viewId === 'view-salida') status.innerHTML = '<span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span> MÓDULO DE SALIDA ACTIVADO';
        }

        // 3. Petición POST para INGRESO
        async function enviarIngreso(e) {
            e.preventDefault();
            const btn = document.getElementById('btn-submit-ingreso');
            btn.innerHTML = 'PROCESANDO...';
            btn.disabled = true;

            const datos = {
                cedula: document.getElementById('in_cedula').value.trim(),
                nombre_completo: document.getElementById('in_nombre').value.trim(),
                empresa: document.getElementById('in_empresa').value.trim() || 'N/A',
                tipo_visitante: document.getElementById('in_tipo').value,
                a_quien_visita: document.getElementById('in_visita_a').value.trim(),
                arl: document.getElementById('in_arl').value,
                tarjeta_asignada: document.getElementById('in_tarjeta').value.trim()
            };

            try {
                const response = await fetch('/recepcion/api/ingreso', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(datos)
                });
                
                const result = await response.json();
                
                if (response.ok) {
                    Swal.fire({
                        title: '¡Ingreso Autorizado!',
                        text: 'Bienvenido a las instalaciones de Impleseg.',
                        icon: 'success',
                        background: '#1e293b',
                        color: 'white',
                        confirmButtonColor: '#f97316'
                    });
                    document.getElementById('form-ingreso').reset();
                    showView('view-menu');
                } else {
                    Swal.fire('Error', result.detail || 'Ocurrió un problema.', 'error');
                }
            } catch (error) {
                Swal.fire('Error de conexión', 'No se pudo conectar con el servidor.', 'error');
            } finally {
                btn.innerHTML = 'REGISTRAR INGRESO';
                btn.disabled = false;
            }
        }

        // 4. Petición POST para SALIDA
        async function enviarSalida(e) {
            e.preventDefault();
            const btn = document.getElementById('btn-submit-salida');
            btn.innerHTML = 'BUSCANDO REGISTRO...';
            btn.disabled = true;

            const cedula = document.getElementById('out_cedula').value.trim();

            try {
                const response = await fetch('/recepcion/api/salida', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cedula: cedula })
                });
                
                const result = await response.json();
                
                if (response.ok) {
                    Swal.fire({
                        title: '¡Salida Registrada!',
                        text: result.mensaje,
                        icon: 'success',
                        background: '#1e293b',
                        color: 'white',
                        confirmButtonColor: '#22c55e'
                    });
                    document.getElementById('form-salida').reset();
                    showView('view-menu');
                } else {
                    Swal.fire({
                        title: 'Aviso',
                        text: result.detail || 'Ocurrió un problema.',
                        icon: 'warning',
                        background: '#1e293b',
                        color: 'white'
                    });
                }
            } catch (error) {
                Swal.fire('Error de conexión', 'No se pudo conectar con el servidor.', 'error');
            } finally {
                btn.innerHTML = 'REGISTRAR SALIDA';
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>